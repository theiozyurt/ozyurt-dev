---
/**
 * Sayfa bazlı tam ekran arka plan motifleri — docs/background_animations/
 * kaynağından uyarlandı (OZYURT-BACKGROUNDS-GUIDE.md).
 *
 * Sayfa → motif eşleşmesi (guide'daki tablo):
 *   dust    → Ana Sayfa (derinlik tozu — kişisel imza, final)
 *   haze    → Portfolyo (derinlik sisi — yumuşak bokeh lekeleri)
 *   bricks / skyline / compass → (kullanım dışı; istenirse hazır)
 *   flight  → Deneyim (uçuş rotası şeritleri)
 *   nodes   → Projeler (düğüm ağı)
 *   trail   → Hedefler (yükselen kıvılcımlar)
 *   grid    → CV (sessiz terminal ızgarası)
 *   signal  → İletişim (radar pingleri; tıklayınca yeni ping)
 *   formation → Liderlik (lideri V formasyonunda takip eden sürü)
 *
 * DNA helix BURADA YOK — o yalnızca Ceviz yüzeylerinde (DnaHelix.astro).
 * Tüm motifler brass (176,141,79) kullanır; mavi Ceviz'in kimliğidir.
 * prefers-reduced-motion: tek kare çizilir, döngü kurulmaz.
 */
interface Props {
  motif:
    | 'dust'
    | 'bricks'
    | 'skyline'
    | 'compass'
    | 'flight'
    | 'nodes'
    | 'trail'
    | 'grid'
    | 'signal'
    | 'formation'
    | 'haze';
}
const { motif } = Astro.props;
---

<canvas class="page-bg" data-page-bg={motif} aria-hidden="true"></canvas>

<script>
  type Opts = Record<string, any>;

  function common(canvas: HTMLCanvasElement, o: Opts) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mouse = { x: -1000, y: -1000 };
    function dims() {
      if (o.fullscreen) return { w: window.innerWidth, h: window.innerHeight };
      const r = canvas.getBoundingClientRect();
      return { w: Math.max(1, Math.round(r.width)), h: Math.max(1, Math.round(r.height)) };
    }
    window.addEventListener(
      'mousemove',
      (e) => {
        const r = o.fullscreen ? { left: 0, top: 0 } : canvas.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
      },
      { passive: true }
    );
    window.addEventListener('mouseleave', () => {
      mouse.x = -1000;
      mouse.y = -1000;
    });
    return { reduce, mouse, dims };
  }

  // ---- Derinlik Tozu — Ana Sayfa kişisel imzası (final) ----
  // Dört farklı derinlikte süzülen toz/parçacık katmanı. Mouse'a sert değil,
  // gecikmeli (eased) paralaks ile tepki verir — derinlik hissi buradan gelir.
  // En öndeki katmanda ara sıra beliren 4 uçlu pırıltılar dışında hiçbir
  // figüratif şekil yok; tamamen soyut, sakin, içerikle yarışmayan bir zemin.
  function createDepthDust(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        accent: '176, 141, 79',
        dimAccent: '124, 140, 166',
        parallaxEase: 0.04,
        sparkleCycle: 14,
        sparkleDuration: 1.6,
        // Katmanlar: arkadan öne. n = 1400x800 referans yoğunluk (alanla
        // ölçeklenir), par = paralaks şiddeti (px), drift = yatay süzülme (px/s).
        layers: [
          { n: 150, size: 0.7, alpha: 0.1, drift: 2, par: 4, useAccent: false, sparkle: false },
          { n: 110, size: 1.0, alpha: 0.17, drift: 4, par: 10, useAccent: false, sparkle: false },
          { n: 75, size: 1.4, alpha: 0.26, drift: 7, par: 20, useAccent: true, sparkle: false },
          { n: 40, size: 2.0, alpha: 0.42, drift: 11, par: 34, useAccent: true, sparkle: true },
        ],
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    const par = { x: 0, y: 0 };
    let layers: any[] = [];

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      const areaScale = (canvas.width * canvas.height) / (1400 * 800);
      layers = o.layers.map((L: any) => {
        const pts = [];
        const count = Math.max(8, Math.round(L.n * areaScale));
        for (let i = 0; i < count; i++) {
          pts.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            ph: Math.random() * Math.PI * 2,
            vSeed: 0.5 + Math.random(),
            sparkleAt: Math.random() * o.sparkleCycle * 1.5,
          });
        }
        return Object.assign({}, L, { pts });
      });
    }

    function sparklePath(x: number, y: number, r: number, rot: number) {
      const inner = r * 0.35;
      ctx.beginPath();
      for (let i = 0; i < 8; i++) {
        const a = rot + (i * Math.PI) / 4;
        const rad = i % 2 === 0 ? r : inner;
        const px = x + Math.cos(a) * rad;
        const py = y + Math.sin(a) * rad;
        i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
      }
      ctx.closePath();
    }

    function frame(now: number) {
      const t = now * 0.001;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const tx = mouse.x > -500 ? (mouse.x - canvas.width / 2) / (canvas.width / 2) : 0;
      const ty = mouse.y > -500 ? (mouse.y - canvas.height / 2) / (canvas.height / 2) : 0;
      par.x += (tx - par.x) * o.parallaxEase;
      par.y += (ty - par.y) * o.parallaxEase;

      layers.forEach((L) => {
        const color = L.useAccent ? o.accent : o.dimAccent;
        L.pts.forEach((p: any) => {
          const driftX = reduce ? 0 : t * L.drift;
          const x =
            ((((p.x + driftX) % canvas.width) + canvas.width) % canvas.width) - par.x * L.par;
          const y = p.y + (reduce ? 0 : Math.sin(t * 0.35 * p.vSeed + p.ph) * 5) - par.y * L.par;
          const tw = reduce ? 0.5 : (Math.sin(t * 0.6 * p.vSeed + p.ph) + 1) / 2;
          const a = L.alpha * (0.55 + tw * 0.65);

          if (L.sparkle && !reduce) {
            const cyc = (t + p.sparkleAt) % o.sparkleCycle;
            if (cyc < o.sparkleDuration) {
              const s = Math.sin((cyc / o.sparkleDuration) * Math.PI);
              sparklePath(x, y, L.size * (1.8 + s * 2.4), t * 0.4 + p.ph);
              ctx.fillStyle = `rgba(${o.accent}, ${a * 0.5 + s * 0.5})`;
              ctx.fill();
              return;
            }
          }
          ctx.beginPath();
          ctx.arc(x, y, L.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${color}, ${a})`;
          ctx.fill();
        });
      });

      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame(performance.now());
  }

  // ---- Derinlik Sisi — Portfolyo zemini ----
  // Ana Sayfa'nın derinlik tozuyla akraba ama ayrı bir imza: sert nokta +
  // 4 uçlu yıldız yerine, dört derinlikte YUMUŞAK ışık lekeleri (bokeh)
  // çapraz süzülür. Aynı gecikmeli paralaks derinlik hissi; farklı doku.
  function createDepthHaze(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        accent: '176, 141, 79',
        dimAccent: '124, 140, 166',
        parallaxEase: 0.045,
        // Katmanlar: arkadan öne. n = 1400x800 referans yoğunluk (alanla
        // ölçeklenir), size = leke yarıçapı (px), driftX/Y = çapraz süzülme
        // (px/s), par = paralaks şiddeti (px).
        layers: [
          { n: 90, size: 6, alpha: 0.06, driftX: 3, driftY: -1.5, par: 5, useAccent: false },
          { n: 58, size: 10, alpha: 0.09, driftX: 5, driftY: -2.5, par: 12, useAccent: false },
          { n: 36, size: 16, alpha: 0.13, driftX: 8, driftY: -4, par: 22, useAccent: true },
          { n: 20, size: 24, alpha: 0.18, driftX: 12, driftY: -6, par: 36, useAccent: true },
        ],
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    const par = { x: 0, y: 0 };
    let layers: any[] = [];

    // Yumuşak leke sprite'ı bir kez çizilir (perf: her karede radial gradient
    // üretmek yerine hazır dokuyu drawImage ile ölçekleyip basıyoruz).
    function makeSprite(rgb: string) {
      const s = document.createElement('canvas');
      const R = 64;
      s.width = s.height = R * 2;
      const g = s.getContext('2d');
      if (!g) return s;
      const grad = g.createRadialGradient(R, R, 0, R, R, R);
      grad.addColorStop(0, `rgba(${rgb}, 0.9)`);
      grad.addColorStop(0.4, `rgba(${rgb}, 0.32)`);
      grad.addColorStop(1, `rgba(${rgb}, 0)`);
      g.fillStyle = grad;
      g.beginPath();
      g.arc(R, R, R, 0, Math.PI * 2);
      g.fill();
      return s;
    }
    const spriteAccent = makeSprite(o.accent);
    const spriteDim = makeSprite(o.dimAccent);

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      const areaScale = (canvas.width * canvas.height) / (1400 * 800);
      layers = o.layers.map((L: any) => {
        const pts = [];
        const count = Math.max(6, Math.round(L.n * areaScale));
        for (let i = 0; i < count; i++) {
          pts.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            ph: Math.random() * Math.PI * 2,
            vSeed: 0.5 + Math.random(),
          });
        }
        return Object.assign({}, L, { pts });
      });
    }

    function frame(now: number) {
      const t = now * 0.001;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const tx = mouse.x > -500 ? (mouse.x - canvas.width / 2) / (canvas.width / 2) : 0;
      const ty = mouse.y > -500 ? (mouse.y - canvas.height / 2) / (canvas.height / 2) : 0;
      par.x += (tx - par.x) * o.parallaxEase;
      par.y += (ty - par.y) * o.parallaxEase;

      layers.forEach((L) => {
        const sprite = L.useAccent ? spriteAccent : spriteDim;
        L.pts.forEach((p: any) => {
          const dx = reduce ? 0 : t * L.driftX;
          const dy = reduce ? 0 : t * L.driftY;
          const x = ((((p.x + dx) % canvas.width) + canvas.width) % canvas.width) - par.x * L.par;
          const y =
            ((((p.y + dy) % canvas.height) + canvas.height) % canvas.height) - par.y * L.par;
          const tw = reduce ? 0.6 : (Math.sin(t * 0.5 * p.vSeed + p.ph) + 1) / 2;
          const a = L.alpha * (0.5 + tw * 0.7);
          const r = L.size;

          ctx.globalAlpha = a;
          ctx.drawImage(sprite, x - r, y - r, r * 2, r * 2);
          ctx.globalAlpha = 1;
        });
      });

      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame(performance.now());
  }

  // ---- Duvar Katmanları — Ana Sayfa kişisel imzası (v3) ----
  // Üç farklı derinlikte, çok düşük opaklıkta, yavaşça kayan tuğla duvar
  // dokusu (running-bond örgü). İçerikle yarışmaz, sadece dokusal bir zemin.
  // Mouse sadece en öndeki katmanı çok hafif aydınlatır.
  function createBrickLayers(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        brickW: 96,
        brickH: 34,
        accent: '176, 141, 79',
        mortar: '124, 140, 166',
        mouseRadius: 260,
        mouseBoost: 0.05,
        layers: [
          { scale: 0.75, alpha: 0.028, speedX: 0.006, speedY: 0 },
          { scale: 1.0, alpha: 0.045, speedX: -0.004, speedY: 0.002 },
          { scale: 1.35, alpha: 0.065, speedX: 0.002, speedY: -0.003 },
        ],
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let startTime: number | null = null;

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
    }

    // Sabit, konuma bağlı sahte-rastgele değer (kaydırma sırasında tuğlalar
    // titremesin diye satır/sütun indeksine göre deterministik hash).
    function hash(row: number, col: number, layerIndex: number) {
      const v = Math.sin(row * 12.9898 + col * 78.233 + layerIndex * 37.719) * 43758.5453;
      return v - Math.floor(v);
    }

    function drawLayer(layer: any, layerIndex: number, time: number, isFront: boolean) {
      const bw = o.brickW * layer.scale;
      const bh = o.brickH * layer.scale;
      const offsetX = time * layer.speedX * 60;
      const offsetY = time * layer.speedY * 60;

      const startCol = Math.floor(-offsetX / bw) - 2;
      const endCol = Math.ceil((canvas.width - offsetX) / bw) + 2;
      const startRow = Math.floor(-offsetY / bh) - 1;
      const endRow = Math.ceil((canvas.height - offsetY) / bh) + 1;

      for (let row = startRow; row <= endRow; row++) {
        const rowShift = row % 2 !== 0 ? bw / 2 : 0; // running-bond örgü
        for (let col = startCol; col <= endCol; col++) {
          const x = col * bw + rowShift + offsetX;
          const y = row * bh + offsetY;

          const jitter = hash(row, col, layerIndex);
          let alpha = layer.alpha * (0.6 + jitter * 0.8);

          if (isFront && mouse.x > -500) {
            const dist = Math.hypot(mouse.x - (x + bw / 2), mouse.y - (y + bh / 2));
            if (dist < o.mouseRadius) alpha += (1 - dist / o.mouseRadius) * o.mouseBoost;
          }

          // çok hafif dolgu — "duvar" hissi için
          ctx.fillStyle = `rgba(${o.mortar}, ${alpha * 0.5})`;
          ctx.fillRect(x, y, bw - 1.5, bh - 1.5);

          // ince derz (mortar) çizgisi
          ctx.strokeStyle = `rgba(${o.mortar}, ${alpha})`;
          ctx.lineWidth = 1;
          ctx.strokeRect(x, y, bw - 1.5, bh - 1.5);
        }
      }
    }

    function frame(now: number) {
      if (startTime === null) startTime = now;
      const time = (now - startTime) / 1000;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      o.layers.forEach((layer: any, i: number) => {
        drawLayer(layer, i, time, i === o.layers.length - 1);
      });
      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame(performance.now());
  }

  // ---- Yükselen Ufuk Çizgisi — Ana Sayfa kişisel imzası ----
  // Alt kısımda yavaşça yükselip yeniden şekillenen soyut blok silüetleri —
  // "sürekli inşa etme / büyüme" metaforu. Mouse yaklaşınca o bölgedeki
  // binalar büyür; en yüksek binanın tepesinde yanıp sönen bir vinç ucu var.
  function createSkylineGrowth(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        barCount: 42,
        barGap: 3,
        accent: '176, 141, 79',
        dimAccent: '124, 140, 166',
        fillAlpha: 0.1,
        topLineAlpha: 0.4,
        maxHeightRatio: 0.55,
        minHeightRatio: 0.08,
        mouseRadius: 220,
        mouseBoostRatio: 0.22,
        starCount: 70,
        starAlpha: 0.08,
        craneBlink: true,
        craneRecalcMs: 2200,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let bars: any[] = [];
    let stars: any[] = [];
    let craneIndex = 0;
    let lastCraneCheck = 0;

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      bars = [];
      const w = canvas.width / o.barCount;
      for (let i = 0; i < o.barCount; i++) {
        bars.push({
          x: i * w,
          w: w - o.barGap,
          phase1: Math.random() * Math.PI * 2,
          phase2: Math.random() * Math.PI * 2,
          freq1: 0.06 + Math.random() * 0.05,
          freq2: 0.02 + Math.random() * 0.03,
          baseRatio: o.minHeightRatio + Math.random() * 0.15,
        });
      }
      stars = [];
      for (let i = 0; i < o.starCount; i++) {
        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height * 0.7,
          flickerUntil: 0,
        });
      }
    }

    function barHeight(bar: any, time: number) {
      const wobble =
        (Math.sin(time * bar.freq1 + bar.phase1) + Math.sin(time * bar.freq2 + bar.phase2)) / 2;
      const ratio = bar.baseRatio + (wobble * 0.5 + 0.5) * (o.maxHeightRatio - bar.baseRatio);
      return Math.max(o.minHeightRatio, Math.min(o.maxHeightRatio, ratio)) * canvas.height;
    }

    function frame(now: number) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const time = now * 0.001;

      stars.forEach((s) => {
        if (now > s.flickerUntil && Math.random() < 0.0012)
          s.flickerUntil = now + 400 + Math.random() * 500;
        const alpha = now < s.flickerUntil ? o.starAlpha * 3 : o.starAlpha;
        ctx.beginPath();
        ctx.arc(s.x, s.y, 0.8, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${o.dimAccent}, ${alpha})`;
        ctx.fill();
      });

      if (now - lastCraneCheck > o.craneRecalcMs) {
        lastCraneCheck = now;
        let maxH = -1;
        bars.forEach((b, i) => {
          const h = barHeight(b, time);
          if (h > maxH) {
            maxH = h;
            craneIndex = i;
          }
        });
      }

      bars.forEach((bar, i) => {
        let h = barHeight(bar, time);
        const barCenterX = bar.x + bar.w / 2;
        const dist = Math.abs(mouse.x - barCenterX);
        if (mouse.x > -500 && dist < o.mouseRadius) {
          h += (1 - dist / o.mouseRadius) * o.mouseBoostRatio * canvas.height;
        }
        h = Math.min(h, canvas.height * (o.maxHeightRatio + o.mouseBoostRatio));
        const y = canvas.height - h;

        ctx.fillStyle = `rgba(${o.accent}, ${o.fillAlpha})`;
        ctx.fillRect(bar.x, y, bar.w, h);

        ctx.beginPath();
        ctx.moveTo(bar.x, y);
        ctx.lineTo(bar.x + bar.w, y);
        ctx.strokeStyle = `rgba(${o.accent}, ${o.topLineAlpha})`;
        ctx.lineWidth = 1;
        ctx.stroke();

        if (o.craneBlink && i === craneIndex) {
          const craneX = bar.x + bar.w / 2;
          const craneTopY = y - 18;
          ctx.beginPath();
          ctx.moveTo(craneX, y);
          ctx.lineTo(craneX, craneTopY);
          ctx.strokeStyle = `rgba(${o.dimAccent}, 0.35)`;
          ctx.lineWidth = 0.8;
          ctx.stroke();
          const blink = reduce ? 1 : (Math.sin(time * 2) + 1) / 2;
          ctx.beginPath();
          ctx.arc(craneX, craneTopY, 1.6, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${o.accent}, ${0.3 + blink * 0.5})`;
          ctx.fill();
        }
      });

      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame(performance.now());
  }

  // ---- Pusula/Rota — Ana Sayfa kişisel imzası ----
  function createCompassBearing(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        accent: '176, 141, 79',
        dimAccent: '124, 140, 166',
        dotSpacing: 46,
        dotAlpha: 0.07,
        twinkleChance: 0.0015,
        routeCount: 4,
        needleEase: 0.06,
        sweepSpeed: 0.25,
        mouseLineMaxDist: 420,
        showBearingLabel: true,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let dots: any[] = [];
    let routes: number[] = [];
    let needleAngle = 0;
    let sweepAngle = -Math.PI / 2;
    let lastTime: number | null = null;

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      dots = [];
      for (let x = o.dotSpacing / 2; x < canvas.width; x += o.dotSpacing)
        for (let y = o.dotSpacing / 2; y < canvas.height; y += o.dotSpacing)
          dots.push({ x, y, flickerUntil: 0 });
      routes = [];
      for (let i = 0; i < o.routeCount; i++) routes.push(Math.random() * Math.PI * 2);
    }

    function center() {
      return { x: canvas.width / 2, y: canvas.height / 2, r: Math.min(canvas.width, canvas.height) * 0.16 };
    }

    function frame(now: number) {
      if (lastTime === null) lastTime = now;
      const dt = Math.min((now - lastTime) / 1000, 0.05);
      lastTime = now;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const c = center();

      dots.forEach((d) => {
        if (now > d.flickerUntil && Math.random() < o.twinkleChance)
          d.flickerUntil = now + 500 + Math.random() * 600;
        const alpha = now < d.flickerUntil ? o.dotAlpha * 3.5 : o.dotAlpha;
        ctx.beginPath();
        ctx.arc(d.x, d.y, 0.9, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${o.dimAccent}, ${alpha})`;
        ctx.fill();
      });

      routes.forEach((a) => {
        ctx.beginPath();
        ctx.moveTo(c.x, c.y);
        ctx.lineTo(c.x + Math.cos(a) * c.r * 4, c.y + Math.sin(a) * c.r * 4);
        ctx.setLineDash([2, 10]);
        ctx.strokeStyle = `rgba(${o.dimAccent}, 0.08)`;
        ctx.lineWidth = 0.6;
        ctx.stroke();
        ctx.setLineDash([]);
      });

      sweepAngle += o.sweepSpeed * dt;
      for (let i = 0; i < 14; i++) {
        const a = sweepAngle - i * 0.05;
        ctx.beginPath();
        ctx.moveTo(c.x, c.y);
        ctx.lineTo(c.x + Math.cos(a) * c.r, c.y + Math.sin(a) * c.r);
        ctx.strokeStyle = `rgba(${o.accent}, ${0.14 * (1 - i / 14)})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }

      const targetAngle = mouse.x > -500 ? Math.atan2(mouse.y - c.y, mouse.x - c.x) : sweepAngle;
      let diff = targetAngle - needleAngle;
      while (diff > Math.PI) diff -= Math.PI * 2;
      while (diff < -Math.PI) diff += Math.PI * 2;
      needleAngle += diff * o.needleEase;

      // pusula gülü
      ctx.beginPath();
      ctx.arc(c.x, c.y, c.r, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${o.accent}, 0.16)`;
      ctx.lineWidth = 1;
      ctx.stroke();
      for (let deg = 0; deg < 360; deg += 15) {
        const a = (deg * Math.PI) / 180;
        const isCardinal = deg % 90 === 0;
        const inner = isCardinal ? c.r * 0.78 : c.r * 0.88;
        ctx.beginPath();
        ctx.moveTo(c.x + Math.cos(a) * inner, c.y + Math.sin(a) * inner);
        ctx.lineTo(c.x + Math.cos(a) * c.r, c.y + Math.sin(a) * c.r);
        ctx.strokeStyle = `rgba(${o.accent}, ${isCardinal ? 0.35 : 0.14})`;
        ctx.lineWidth = isCardinal ? 1.2 : 0.7;
        ctx.stroke();
      }
      ctx.font = '11px monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = `rgba(${o.accent}, 0.4)`;
      (
        [
          ['N', -Math.PI / 2],
          ['E', 0],
          ['S', Math.PI / 2],
          ['W', Math.PI],
        ] as [string, number][]
      ).forEach(([label, a]) => {
        ctx.fillText(label, c.x + Math.cos(a) * c.r * 0.66, c.y + Math.sin(a) * c.r * 0.66);
      });

      // mouse'a rota çizgisi + derece okuması
      if (mouse.x > -500) {
        const dx = mouse.x - c.x,
          dy = mouse.y - c.y;
        const dist = Math.min(Math.hypot(dx, dy), o.mouseLineMaxDist);
        const angle = Math.atan2(dy, dx);
        const x2 = c.x + Math.cos(angle) * dist;
        const y2 = c.y + Math.sin(angle) * dist;
        ctx.beginPath();
        ctx.moveTo(c.x, c.y);
        ctx.lineTo(x2, y2);
        ctx.setLineDash([1, 6]);
        ctx.strokeStyle = `rgba(${o.accent}, 0.25)`;
        ctx.lineWidth = 0.8;
        ctx.stroke();
        ctx.setLineDash([]);
        if (o.showBearingLabel) {
          const deg = Math.round(((angle * 180) / Math.PI + 90 + 360) % 360);
          ctx.font = '11px monospace';
          ctx.textAlign = 'left';
          ctx.fillStyle = `rgba(${o.accent}, 0.55)`;
          ctx.fillText(`${String(deg).padStart(3, '0')}°`, x2 + 8, y2);
        }
      }

      // ibre
      ctx.beginPath();
      ctx.moveTo(c.x, c.y);
      ctx.lineTo(c.x + Math.cos(needleAngle) * c.r * 0.92, c.y + Math.sin(needleAngle) * c.r * 0.92);
      ctx.strokeStyle = `rgba(${o.accent}, 0.85)`;
      ctx.lineWidth = 1.6;
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(c.x, c.y);
      ctx.lineTo(c.x - Math.cos(needleAngle) * c.r * 0.34, c.y - Math.sin(needleAngle) * c.r * 0.34);
      ctx.strokeStyle = `rgba(${o.dimAccent}, 0.5)`;
      ctx.lineWidth = 1.3;
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(c.x, c.y, 2.4, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${o.accent}, 0.9)`;
      ctx.fill();

      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    if (reduce) {
      needleAngle = -Math.PI / 2; // tek kare: ibre kuzeye sabit
      frame(performance.now());
    } else {
      requestAnimationFrame(frame);
    }
  }

  // ---- Uçuş Rotası — Deneyim ----
  function createFlightPath(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        laneCount: 6,
        laneSpacing: null,
        trailCount: 22,
        speed: 0.6,
        arcHeight: 26,
        accent: '176, 141, 79',
        baseAlpha: 0.16,
        trailLength: 40,
        mouseRadius: 150,
        headSize: 1.4,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let lanes: any[] = [];

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      lanes = [];
      const spacing = o.laneSpacing || canvas.height / (o.laneCount + 1);
      for (let i = 1; i <= o.laneCount; i++) {
        const particles = [];
        for (let j = 0; j < o.trailCount; j++)
          particles.push({ t: Math.random(), seed: Math.random() * Math.PI * 2 });
        lanes.push({ baseY: spacing * i, dir: i % 2 === 0 ? -1 : 1, particles });
      }
    }

    function frame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const time = performance.now() * 0.001;
      lanes.forEach((lane) => {
        lane.particles.forEach((p: any) => {
          p.t += o.speed * 0.0006 * lane.dir;
          if (p.t > 1) p.t = 0;
          if (p.t < 0) p.t = 1;
          const x = lane.dir > 0 ? p.t * canvas.width : (1 - p.t) * canvas.width;
          const y = lane.baseY + Math.sin(x * 0.01 + p.seed + time * 0.2) * o.arcHeight;
          const dist = Math.hypot(mouse.x - x, mouse.y - y);
          let alpha = o.baseAlpha;
          if (dist < o.mouseRadius) alpha = o.baseAlpha + (1 - dist / o.mouseRadius) * 0.6;
          const tailX = x - lane.dir * o.trailLength;
          const grad = ctx.createLinearGradient(tailX, y, x, y);
          grad.addColorStop(0, `rgba(${o.accent}, 0)`);
          grad.addColorStop(1, `rgba(${o.accent}, ${alpha})`);
          ctx.strokeStyle = grad;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(tailX, y);
          ctx.lineTo(x, y);
          ctx.stroke();
          ctx.beginPath();
          ctx.arc(x, y, o.headSize, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${o.accent}, ${Math.min(alpha + 0.2, 1)})`;
          ctx.fill();
        });
      });
      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame();
  }

  // ---- Düğüm Ağı — Projeler ----
  function createNodeNetwork(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        nodeCount: 60,
        linkDistance: 140,
        driftSpeed: 0.15,
        accent: '176, 141, 79',
        baseAlpha: 0.5,
        linkAlpha: 0.12,
        nodeSize: 1.6,
        mouseRadius: 160,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let nodes: any[] = [];

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      const count = Math.round((o.nodeCount * (canvas.width * canvas.height)) / (1400 * 800));
      nodes = [];
      for (let i = 0; i < Math.max(count, 12); i++) {
        nodes.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * o.driftSpeed,
          vy: (Math.random() - 0.5) * o.driftSpeed,
        });
      }
    }

    function frame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      nodes.forEach((n) => {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < 0 || n.x > canvas.width) n.vx *= -1;
        if (n.y < 0 || n.y > canvas.height) n.vy *= -1;
      });
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i],
            b = nodes[j];
          const dist = Math.hypot(a.x - b.x, a.y - b.y);
          if (dist < o.linkDistance) {
            const mDist = Math.hypot(mouse.x - (a.x + b.x) / 2, mouse.y - (a.y + b.y) / 2);
            let alpha = o.linkAlpha * (1 - dist / o.linkDistance);
            if (mDist < o.mouseRadius) alpha += (1 - mDist / o.mouseRadius) * 0.35;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = `rgba(${o.accent}, ${alpha})`;
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }
      }
      nodes.forEach((n) => {
        const dist = Math.hypot(mouse.x - n.x, mouse.y - n.y);
        let alpha = o.baseAlpha * 0.4;
        let size = o.nodeSize;
        if (dist < o.mouseRadius) {
          const f = 1 - dist / o.mouseRadius;
          alpha = o.baseAlpha * 0.4 + f * 0.5;
          size = o.nodeSize + f * 1.6;
        }
        ctx.beginPath();
        ctx.arc(n.x, n.y, size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${o.accent}, ${alpha})`;
        ctx.fill();
      });
      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame();
  }

  // ---- Yükselen İz — Hedefler ----
  function createAscendingTrail(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        particleCount: 70,
        baseSpeed: 0.35,
        drift: 18,
        accent: '176, 141, 79',
        baseAlpha: 0.22,
        tailLength: 26,
        mouseRadius: 130,
        mouseBoost: 1.4,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let particles: any[] = [];

    function spawn(p: any) {
      p.x = Math.random() * canvas.width;
      p.y = canvas.height + Math.random() * 40;
      p.speed = o.baseSpeed * (0.6 + Math.random() * 0.8);
      p.seed = Math.random() * Math.PI * 2;
      p.size = 0.8 + Math.random() * 1.2;
    }

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      particles = [];
      for (let i = 0; i < o.particleCount; i++) {
        const p: any = {};
        spawn(p);
        p.y = Math.random() * canvas.height;
        particles.push(p);
      }
    }

    function frame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const time = performance.now() * 0.001;
      particles.forEach((p) => {
        p.y -= p.speed;
        p.x += Math.sin(time * 0.5 + p.seed) * o.drift * 0.02;
        if (p.y < -20) spawn(p);
        const dist = Math.hypot(mouse.x - p.x, mouse.y - p.y);
        let alpha = o.baseAlpha;
        let size = p.size;
        if (dist < o.mouseRadius) {
          const f = 1 - dist / o.mouseRadius;
          alpha = o.baseAlpha + f * 0.6;
          size = p.size + f * 1.5;
          p.y -= p.speed * f * (o.mouseBoost - 1);
        }
        const grad = ctx.createLinearGradient(p.x, p.y + o.tailLength, p.x, p.y);
        grad.addColorStop(0, `rgba(${o.accent}, 0)`);
        grad.addColorStop(1, `rgba(${o.accent}, ${alpha})`);
        ctx.strokeStyle = grad;
        ctx.lineWidth = size * 0.8;
        ctx.beginPath();
        ctx.moveTo(p.x, p.y + o.tailLength);
        ctx.lineTo(p.x, p.y);
        ctx.stroke();
        ctx.beginPath();
        ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${o.accent}, ${Math.min(alpha + 0.15, 1)})`;
        ctx.fill();
      });
      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame();
  }

  // ---- Terminal Grid — CV (bilerek çok sessiz) ----
  function createTerminalGrid(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        cellSize: 26,
        accent: '176, 141, 79',
        baseAlpha: 0.05,
        flickerChance: 0.0025,
        flickerAlpha: 0.4,
        flickerDuration: 900,
        chars: '01/_-.:[]#',
        fontSize: 12,
        mouseRadius: 110,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let cells: any[] = [];

    function randomChar() {
      return o.chars[Math.floor(Math.random() * o.chars.length)];
    }

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      cells = [];
      const cols = Math.ceil(canvas.width / o.cellSize);
      const rows = Math.ceil(canvas.height / o.cellSize);
      for (let cx = 0; cx < cols; cx++)
        for (let cy = 0; cy < rows; cy++)
          cells.push({
            x: cx * o.cellSize + o.cellSize / 2,
            y: cy * o.cellSize + o.cellSize / 2,
            char: randomChar(),
            flickerUntil: 0,
          });
    }

    function frame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.font = `${o.fontSize}px monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      const now = performance.now();
      cells.forEach((c) => {
        if (now > c.flickerUntil && Math.random() < o.flickerChance) {
          c.flickerUntil = now + o.flickerDuration;
          c.char = randomChar();
        }
        const dist = Math.hypot(mouse.x - c.x, mouse.y - c.y);
        let alpha = o.baseAlpha;
        if (now < c.flickerUntil) alpha = o.flickerAlpha;
        if (dist < o.mouseRadius) alpha = Math.max(alpha, (1 - dist / o.mouseRadius) * 0.5);
        ctx.fillStyle = `rgba(${o.accent}, ${alpha})`;
        ctx.fillText(c.char, c.x, c.y);
      });
      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame();
  }

  // ---- Sinyal Dalgası — İletişim ----
  function createSignalPulse(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        anchorCount: 4,
        pulseInterval: 2200,
        maxRadius: 260,
        speed: 60,
        accent: '176, 141, 79',
        baseAlpha: 0.35,
        lineWidth: 1,
        mouseRadius: 150,
        clickSpawn: true,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    let anchors: any[] = [];
    let pulses: any[] = [];

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      anchors = [];
      for (let i = 0; i < o.anchorCount; i++)
        anchors.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          nextPulse: performance.now() + Math.random() * o.pulseInterval,
        });
    }

    function spawnPulse(x: number, y: number) {
      pulses.push({ x, y, r: 0, born: performance.now() });
    }

    function frame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const now = performance.now();
      anchors.forEach((a) => {
        if (now > a.nextPulse) {
          spawnPulse(a.x, a.y);
          a.nextPulse = now + o.pulseInterval * (0.8 + Math.random() * 0.4);
        }
        ctx.beginPath();
        ctx.arc(a.x, a.y, 1.6, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${o.accent}, ${o.baseAlpha})`;
        ctx.fill();
      });
      pulses = pulses.filter((p) => {
        p.r = ((now - p.born) / 1000) * o.speed;
        if (p.r > o.maxRadius) return false;
        const fade = 1 - p.r / o.maxRadius;
        const dist = Math.hypot(mouse.x - p.x, mouse.y - p.y);
        let alpha = o.baseAlpha * fade;
        if (dist < o.mouseRadius) alpha += (1 - dist / o.mouseRadius) * 0.3 * fade;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(${o.accent}, ${alpha})`;
        ctx.lineWidth = o.lineWidth;
        ctx.stroke();
        return true;
      });
      if (!reduce) requestAnimationFrame(frame);
    }

    if (o.clickSpawn && !reduce) {
      // Canvas pointer-events:none olduğundan tıklama window'dan dinlenir.
      window.addEventListener('click', () => {
        if (mouse.x > -500) spawnPulse(mouse.x, mouse.y);
      });
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame();
  }

  // ---- Uçuş Formasyonu — Liderlik ----
  // Önde bir "lider" nokta (mouse varsa mouse, yoksa kendi başına dolaşır),
  // arkasında geciktirilmiş tarihçeyle V formasyonunda takip eden noktalar.
  // Birkaç takipçi diğerlerinden daha parlak (alt-lider / mentor hissi).
  function createLeadershipFormation(canvas: HTMLCanvasElement, options: Opts) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const o = Object.assign(
      {
        fullscreen: false,
        followerCount: 26,
        delayStep: 3,
        lateralGap: 7,
        subLeaderEvery: 6,
        accent: '176, 141, 79',
        dimAccent: '124, 140, 166',
        baseAlpha: 0.5,
        idleRadius: 0.22,
        idleSpeed: 0.15,
        leaderEase: 0.06,
      },
      options || {}
    );
    const { reduce, mouse, dims } = common(canvas, o);
    const leader = { x: 0, y: 0 };
    let history: { x: number; y: number }[] = [];
    let followers: any[] = [];
    let maxHistory = 1;

    function resize() {
      const d = dims();
      canvas.width = d.w;
      canvas.height = d.h;
      leader.x = canvas.width / 2;
      leader.y = canvas.height / 2;
      followers = [];
      maxHistory = o.followerCount * o.delayStep + 5;
      history = new Array(maxHistory).fill(null).map(() => ({ x: leader.x, y: leader.y }));
      for (let i = 0; i < o.followerCount; i++) {
        const side = i % 2 === 0 ? 1 : -1;
        const rank = Math.floor(i / 2);
        followers.push({
          delay: (i + 1) * o.delayStep,
          offset: side * o.lateralGap * (rank + 1),
          isSubLeader: (i + 1) % o.subLeaderEvery === 0,
        });
      }
    }

    function idleTarget(time: number) {
      return {
        x: canvas.width / 2 + Math.cos(time * o.idleSpeed) * canvas.width * o.idleRadius,
        y: canvas.height / 2 + Math.sin(time * o.idleSpeed * 1.3) * canvas.height * o.idleRadius,
      };
    }

    function frame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const time = performance.now() * 0.001;

      const target = mouse.x > -500 ? mouse : idleTarget(time);
      leader.x += (target.x - leader.x) * o.leaderEase;
      leader.y += (target.y - leader.y) * o.leaderEase;

      history.push({ x: leader.x, y: leader.y });
      if (history.length > maxHistory) history.shift();

      const prev = history[Math.max(history.length - 4, 0)];
      const leaderAngle = Math.atan2(leader.y - prev.y, leader.x - prev.x) || 0;

      // lider ile ilk birkaç takipçi arasında ince "organizasyon" çizgileri
      followers.slice(0, 6).forEach((f) => {
        const p = history[Math.max(history.length - 1 - f.delay, 0)];
        ctx.beginPath();
        ctx.moveTo(leader.x, leader.y);
        ctx.lineTo(p.x, p.y);
        ctx.strokeStyle = `rgba(${o.dimAccent}, 0.06)`;
        ctx.lineWidth = 0.5;
        ctx.stroke();
      });

      followers.forEach((f) => {
        const idx = Math.max(history.length - 1 - f.delay, 0);
        const p = history[idx];
        const p2 = history[Math.max(idx - 3, 0)];
        const heading = Math.atan2(p.y - p2.y, p.x - p2.x) || leaderAngle;
        const perpAngle = heading + Math.PI / 2;
        const fx = p.x + Math.cos(perpAngle) * f.offset;
        const fy = p.y + Math.sin(perpAngle) * f.offset;

        const depthFade = 1 - (idx / maxHistory) * 0.5;
        const alpha = (f.isSubLeader ? o.baseAlpha * 0.9 : o.baseAlpha * 0.45) * depthFade;
        const size = f.isSubLeader ? 2.2 : 1.3;
        const color = f.isSubLeader ? o.accent : o.dimAccent;

        // basit üçgen — hareket yönüne bakan takipçi
        ctx.save();
        ctx.translate(fx, fy);
        ctx.rotate(heading);
        ctx.beginPath();
        ctx.moveTo(size * 1.6, 0);
        ctx.lineTo(-size, size * 0.9);
        ctx.lineTo(-size, -size * 0.9);
        ctx.closePath();
        ctx.fillStyle = `rgba(${color}, ${alpha})`;
        ctx.fill();
        ctx.restore();
      });

      // lider noktası
      ctx.save();
      ctx.translate(leader.x, leader.y);
      ctx.rotate(leaderAngle);
      ctx.beginPath();
      ctx.moveTo(4, 0);
      ctx.lineTo(-2.5, 2.2);
      ctx.lineTo(-2.5, -2.2);
      ctx.closePath();
      ctx.fillStyle = `rgba(${o.accent}, 0.9)`;
      ctx.fill();
      ctx.restore();

      if (!reduce) requestAnimationFrame(frame);
    }

    window.addEventListener('resize', resize, { passive: true });
    resize();
    frame();
  }

  function initPageBackgrounds() {
    // Mobilde yoğunluğu düşür (guide'daki performans notu).
    const mobile = window.innerWidth < 768;
    const creators: Record<string, (c: HTMLCanvasElement) => void> = {
      dust: (c) => createDepthDust(c, { fullscreen: true }),
      bricks: (c) => createBrickLayers(c, { fullscreen: true, brickW: mobile ? 72 : 96 }),
      skyline: (c) => createSkylineGrowth(c, { fullscreen: true, barCount: mobile ? 26 : 42 }),
      compass: (c) => createCompassBearing(c, { fullscreen: true }),
      flight: (c) => createFlightPath(c, { fullscreen: true, laneCount: mobile ? 4 : 6 }),
      nodes: (c) => createNodeNetwork(c, { fullscreen: true, nodeCount: mobile ? 40 : 60 }),
      trail: (c) => createAscendingTrail(c, { fullscreen: true, particleCount: mobile ? 45 : 70 }),
      grid: (c) => createTerminalGrid(c, { fullscreen: true, cellSize: mobile ? 34 : 26 }),
      signal: (c) => createSignalPulse(c, { fullscreen: true }),
      formation: (c) => createLeadershipFormation(c, { fullscreen: true, followerCount: mobile ? 16 : 26 }),
      haze: (c) => createDepthHaze(c, { fullscreen: true }),
    };
    document.querySelectorAll<HTMLCanvasElement>('canvas[data-page-bg]').forEach((canvas) => {
      if (canvas.dataset.bgInit) return;
      canvas.dataset.bgInit = '1';
      const motif = canvas.getAttribute('data-page-bg') || '';
      creators[motif]?.(canvas);
    });
  }

  initPageBackgrounds();
</script>
