---
/**
 * Buton — Ceviz buton dili (dolgu/gradient primary + camsı ghost secondary).
 * Terminal parantez sistemi ([ LABEL ]_) emekli oldu (splash hariç).
 *
 * Link:    <Cta href="/projects" variant="primary"><T en=".." tr=".." /></Cta>
 * Buton:   <Cta as="button" type="submit" variant="primary"><T .. /></Cta>
 *
 * `cursor` prop'u artık görsel bir etki yaratmaz; geriye dönük uyum için tutuluyor.
 */
interface Props {
  href?: string;
  as?: 'a' | 'button';
  type?: 'button' | 'submit';
  variant?: 'primary' | 'secondary';
  cursor?: boolean;
  id?: string;
  class?: string;
}
const {
  href,
  as = href ? 'a' : 'button',
  type = 'button',
  variant = 'primary',
  id,
  class: className,
} = Astro.props;

const cls = ['cta', `cta-${variant}`, className].filter(Boolean).join(' ');
---
{as === 'button' ? (
  <button type={type} class={cls} id={id}><slot /></button>
) : (
  <a href={href} class={cls} id={id}><slot /></a>
)}
