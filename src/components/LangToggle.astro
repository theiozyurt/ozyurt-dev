---
// Çift dil geçişi. JS, BaseLayout içinde global olarak dinleniyor.
---
<div class="lang-toggle" role="group" aria-label="Language / Dil">
  <button type="button" data-lang-set="en" aria-pressed="true">EN</button>
  <span class="lang-sep" aria-hidden="true">/</span>
  <button type="button" data-lang-set="tr" aria-pressed="false">TR</button>
</div>

<style>
  .lang-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-body);
    font-size: var(--fs-label);
    letter-spacing: 0.12em;
  }
  .lang-toggle button {
    background: none;
    border: none;
    color: var(--text-muted);
    font: inherit;
    letter-spacing: inherit;
    padding: 0.2rem 0.15rem;
    cursor: pointer;
    transition: color var(--dur) var(--ease);
  }
  .lang-toggle button:hover { color: var(--text-body); }
  .lang-toggle button[aria-pressed='true'] {
    color: var(--accent);
  }
  .lang-sep { color: var(--border); }
</style>
