---
import site from '../data/site.json';
import T from './T.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-name">İsmail Özyurt<span class="footer-dot">.dev</span></span>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <span class="footer-label"><T en="Elsewhere" tr="Diğer" /></span>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        <a href={site.github} target="_blank" rel="noopener">GitHub</a>
        <a href={site.cevizSite} target="_blank" rel="noopener">Ceviz Biyoteknoloji</a>
        <a href={`tel:${site.phone.replace(/\s/g, '')}`}>{site.phone}</a>
      </div>
      <div class="footer-col">
        <span class="footer-label"><T en="Site" tr="Site" /></span>
        {site.nav.filter((n) => n.href !== '/').map((n) => (
          <a href={n.href}><T en={n.en} tr={n.tr} /></a>
        ))}
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <span class="mono">© {year} İsmail Özyurt</span>
    <span class="mono footer-built">by Ozyurt</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    background: var(--bg-primary-darker);
    padding-block: var(--space-2xl) var(--space-lg);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border-faint);
  }
  .footer-name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--text-heading);
  }
  .footer-dot { color: var(--accent); }
  .footer-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: flex-start;
  }
  .footer-col a {
    color: var(--text-body);
    font-size: var(--fs-small);
  }
  .footer-col a:hover { color: var(--accent); }
  .footer-label {
    font-family: var(--font-body);
    font-size: var(--fs-label);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    padding-top: var(--space-lg);
  }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--space-lg); }
  }
</style>
