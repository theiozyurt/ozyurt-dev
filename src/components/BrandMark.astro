---
/**
 * Ozyurt marka işareti — soyut bir "O".
 * Üst-sağda açık bir aralık bırakan (aperture) gradyan halka; yüzük değil,
 * dinamik bir harf/teknoloji işareti okunur. Yumuşak ama belirgin glow.
 * favicon.svg ve og.svg ile aynı dili paylaşır.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 30, class: className } = Astro.props;
// Aynı sayfada birden çok kez kullanılırsa id çakışmasın diye benzersiz ek.
const uid = 'bm' + Math.random().toString(36).slice(2, 8);
---

<svg
  class:list={['brand-o', className]}
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={`${uid}-ring`} x1="7" y1="5" x2="33" y2="35" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#CDE7FF" />
      <stop offset="0.45" stop-color="#6BB7FF" />
      <stop offset="1" stop-color="#2C7FD9" />
    </linearGradient>
    <filter id={`${uid}-glow`} x="-60%" y="-60%" width="220%" height="220%">
      <feGaussianBlur stdDeviation="1.9" result="b" />
      <feMerge>
        <feMergeNode in="b" />
        <feMergeNode in="b" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>
  <!-- Üst-sağda açık, ~40° aralıklı gradyan "O" -->
  <path
    d="M32.24 14.29 A 13.5 13.5 0 1 1 25.70 7.77"
    stroke={`url(#${uid}-ring)`}
    stroke-width="5"
    stroke-linecap="round"
    filter={`url(#${uid}-glow)`}
  />
</svg>

<style>
  .brand-o {
    flex: none;
    display: block;
  }
</style>
