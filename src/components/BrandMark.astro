---
/**
 * Ozyurt marka işareti — "O" harfini soyutlayan camsı/yörünge halkası.
 * Gradyan halka + üstte parlayan bir düğüm (aperture/yörünge hissi) + yumuşak glow.
 * İÖ monogramının yerini alır. favicon.svg ve og.svg ile aynı dili paylaşır.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 30, class: className } = Astro.props;
// Aynı sayfada birden çok kez kullanılırsa id çakışmasın diye benzersiz ek.
const uid = 'bm' + Math.random().toString(36).slice(2, 8);
---

<svg
  class:list={['brand-o', className]}
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={`${uid}-ring`} x1="7" y1="4" x2="33" y2="36" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#B7DCFF" />
      <stop offset="0.5" stop-color="#6BB7FF" />
      <stop offset="1" stop-color="#2C7FD9" />
    </linearGradient>
    <radialGradient id={`${uid}-node`} cx="0.42" cy="0.35" r="0.75">
      <stop offset="0" stop-color="#EAF4FF" />
      <stop offset="1" stop-color="#6BB7FF" />
    </radialGradient>
    <filter id={`${uid}-glow`} x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="1.5" result="b" />
      <feMerge>
        <feMergeNode in="b" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>
  <g filter={`url(#${uid}-glow)`}>
    <!-- Üstte küçük boşluk bırakan gradyan halka (O gövdesi) -->
    <path
      d="M25.06 7.48 A 13.5 13.5 0 1 1 14.94 7.48"
      stroke={`url(#${uid}-ring)`}
      stroke-width="4"
      stroke-linecap="round"
    />
    <!-- Boşlukta duran parlayan yörünge düğümü -->
    <circle cx="20" cy="6.5" r="3.4" fill={`url(#${uid}-node)`} />
  </g>
</svg>

<style>
  .brand-o {
    flex: none;
    display: block;
  }
</style>
