---
/**
 * Paylaşılan galeri bölümü — /projects/[slug], /experience/[slug] ve
 * /leadership/[slug] sayfalarının altında kullanılır.
 * Görsel varsa keskin köşeli bir grid, yoksa placeholder gösterir.
 */
import T from './T.astro';

interface Props {
  images?: string[];
  heading?: string;
}
const { images = [], heading = '[ GALLERY ]' } = Astro.props;
---
<div class="entry-gallery">
  <h3 class="gallery-heading mono">{heading}</h3>
  {images.length > 0 ? (
    <div class="gallery-grid" data-lightbox-group>
      {images.map((img) => (
        <button class="gallery-item" type="button" data-lightbox aria-label="Görseli büyüt">
          <img src={img} alt="" loading="lazy" />
        </button>
      ))}
    </div>
  ) : (
    <div class="gallery-placeholder mono">
      <T en="Images coming soon" tr="Görseller yakında eklenecek" />
    </div>
  )}
</div>

<style>
  .entry-gallery { margin-top: var(--space-xl); }
  .gallery-heading {
    font-size: var(--fs-label);
    letter-spacing: 0.14em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
    margin-top: 24px;
  }
  .gallery-item {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0;
    background: none;
    cursor: pointer;
  }
  .gallery-item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* keskin köşe kuralı — proje/etkinlik görsellerinde yuvarlatma yok */
    filter: grayscale(10%);
    transition: filter 0.3s var(--ease), transform 0.3s var(--ease);
  }
  .gallery-item:hover img {
    filter: grayscale(0%);
    transform: scale(1.03);
  }
  .gallery-placeholder {
    border: 1px dashed var(--border);
    padding: 40px;
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
  }
</style>
