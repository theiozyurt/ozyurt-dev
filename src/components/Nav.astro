---
import site from '../data/site.json';
import LangToggle from './LangToggle.astro';
import BrandMark from './BrandMark.astro';
import T from './T.astro';

interface Props {
  path?: string;
}
const { path = '' } = Astro.props;

function isActive(href: string) {
  if (href === '/') return path === '/' || path === '';
  return path === href || path.startsWith(href + '/');
}
---

<header class="site-nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={`${site.name} — home`}>
      <BrandMark size={30} class="brand-mark" />
      <span class="brand-name">Ozyurt</span>
      <span class="brand-dot">.dev</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {site.nav.filter((n) => n.href !== '/').map((n) => (
        <a
          href={n.href}
          class:list={['nav-link', { 'is-active': isActive(n.href) }]}
          aria-current={isActive(n.href) ? 'page' : undefined}
        >
          <T en={n.en} tr={n.tr} />
        </a>
      ))}
    </nav>

    <div class="nav-right">
      <LangToggle />
      <button
        type="button"
        class="nav-toggle"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span></span><span></span>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile" hidden>
    {site.nav.map((n) => (
      <a
        href={n.href}
        class:list={['mobile-link', { 'is-active': isActive(n.href) }]}
        aria-current={isActive(n.href) ? 'page' : undefined}
      >
        <T en={n.en} tr={n.tr} />
      </a>
    ))}
  </nav>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg-primary) 92%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-faint);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    height: 4.25rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text-heading);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .brand:hover { color: var(--text-heading); }
  .brand-dot { color: var(--accent); }
  .brand-mark { flex: none; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    margin-left: auto;
    margin-right: var(--space-lg);
  }
  .nav-link {
    font-family: var(--font-body);
    font-size: var(--fs-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-body);
    padding-block: 0.4rem;
    position: relative;
  }
  .nav-link:hover { color: var(--text-heading); }
  .nav-link.is-active { color: var(--accent); }
  .nav-link.is-active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -0.15rem;
    height: 1px;
    background: var(--accent);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    background: none;
    border: 1px solid var(--border);
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    height: 1px;
    width: 1.1rem;
    margin-inline: auto;
    background: var(--text-heading);
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .nav-toggle[aria-expanded='true'] span:first-child { transform: translateY(3px) rotate(45deg); }
  .nav-toggle[aria-expanded='true'] span:last-child { transform: translateY(-3px) rotate(-45deg); }

  .mobile-nav {
    display: none;
    flex-direction: column;
    border-top: 1px solid var(--border-faint);
    padding: var(--space-sm) var(--gutter) var(--space-md);
  }
  .mobile-nav:not([hidden]) { display: flex; }
  .mobile-link {
    font-family: var(--font-body);
    font-size: var(--fs-small);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-body);
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border-faint);
  }
  .mobile-link.is-active { color: var(--accent); }

  @media (max-width: 820px) {
    .nav-links { display: none; }
    .nav-toggle { display: flex; }
    .nav-inner { gap: var(--space-md); }
  }
  @media (max-width: 400px) {
    .brand { font-size: 1rem; gap: 0.5rem; }
    .brand-name, .brand-dot { display: none; } /* dar ekranda sadece monogram */
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.querySelector('.nav-toggle');
    var menu = document.getElementById('mobile-nav');
    if (!toggle || !menu) return;
    toggle.addEventListener('click', function () {
      var open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.hidden = open;
    });
    menu.addEventListener('click', function (e) {
      if (e.target.closest('a')) {
        toggle.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
      }
    });
  })();
</script>
