---
import BaseLayout from '../layouts/BaseLayout.astro';
import T from '../components/T.astro';
import Cta from '../components/Cta.astro';
import GhostNumber from '../components/GhostNumber.astro';
import site from '../data/site.json';
---

<BaseLayout
  path="/contact"
  title="Contact"
  description="Get in touch with İsmail Özyurt — email, LinkedIn, or the contact form."
>
  <header class="page-head section ghost-host">
    <GhostNumber n="01" />
    <div class="container">
      <span class="section-label"><T en="Contact" tr="İletişim" /></span>
      <h1><T en="Let's talk." tr="Konuşalım." /></h1>
      <p class="page-lead">
        <T
          en="Building something, hiring, or just curious? The contact form is coming soon — for now, reach me directly through the channels on the left."
          tr="Bir şey mi inşa ediyorsun, işe mi alıyorsun, yoksa sadece merak mı ettin? İletişim formu yakında aktif olacak — şimdilik soldaki kanallardan doğrudan ulaşabilirsin."
        />
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container contact-grid">
      <!-- Direkt kanallar -->
      <div class="contact-channels">
        <span class="section-label"><T en="Direct" tr="Doğrudan" /></span>
        <ul class="channel-list">
          <li>
            <span class="channel-key mono"><T en="Email" tr="E-posta" /></span>
            <a href={`mailto:${site.email}`} class="channel-val">{site.email}</a>
          </li>
          <li>
            <span class="channel-key mono">LinkedIn</span>
            <a href={site.linkedin} target="_blank" rel="noopener" class="channel-val">{site.linkedinLabel}</a>
          </li>
          <li>
            <span class="channel-key mono">GitHub</span>
            <a href={site.github} target="_blank" rel="noopener" class="channel-val">{site.githubLabel}</a>
          </li>
          <li>
            <span class="channel-key mono">Ceviz Biyoteknoloji</span>
            <a href={site.cevizSite} target="_blank" rel="noopener" class="channel-val">{site.cevizSiteLabel}</a>
          </li>
          <li>
            <span class="channel-key mono"><T en="Phone" tr="Telefon" /></span>
            <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="channel-val">{site.phone}</a>
          </li>
          <li>
            <span class="channel-key mono"><T en="Location" tr="Konum" /></span>
            <span class="channel-val">Kütahya, Türkiye</span>
          </li>
        </ul>
      </div>

      <!-- Form -->
      <div class="contact-form-wrap">
        <span class="section-label"><T en="Send a note" tr="Not gönder" /></span>
        <form id="contact-form" class="contact-form" novalidate>
          <div class="field">
            <label for="c-name" class="mono"><T en="Name" tr="Ad Soyad" /></label>
            <input id="c-name" name="name" type="text" required autocomplete="name" maxlength="120"
              data-ph-en="Your name" data-ph-tr="İsmin" />
          </div>
          <div class="field">
            <label for="c-email" class="mono"><T en="Email" tr="E-posta" /></label>
            <input id="c-email" name="email" type="email" required autocomplete="email" maxlength="254"
              data-ph-en="mail@example.com" data-ph-tr="mail@ornek.com" />
          </div>
          <div class="field">
            <label for="c-subject" class="mono"><T en="Subject" tr="Konu" /></label>
            <input id="c-subject" name="subject" type="text" maxlength="160"
              data-ph-en="What's it about?" data-ph-tr="Ne hakkında?" />
          </div>
          <div class="field">
            <label for="c-message" class="mono"><T en="Message" tr="Mesaj" /></label>
            <textarea id="c-message" name="message" rows="5" required maxlength="5000"
              data-ph-en="Hi İsmail, …" data-ph-tr="Merhaba İsmail, …"></textarea>
          </div>

          <!-- Honeypot — botlar için, insanlar görmez -->
          <div class="hp" aria-hidden="true">
            <label for="c-company">Company</label>
            <input id="c-company" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <Cta as="button" type="submit" variant="primary" id="contact-submit">
            <T en="Coming soon" tr="Yakında aktif" />
          </Cta>

          <p class="form-status mono" id="form-status" role="status" aria-live="polite" hidden></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { border-top: none; padding-bottom: var(--space-lg); }
  .page-lead { color: var(--text-body); font-size: 1.15rem; margin-top: var(--space-md); max-width: 56ch; }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .channel-list { list-style: none; border-top: 1px solid var(--border); }
  .channel-list li {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border-faint);
  }
  .channel-key { text-transform: uppercase; letter-spacing: 0.14em; font-size: var(--fs-label); }
  .channel-val { font-family: var(--font-display); font-size: 1.25rem; color: var(--text-heading); }
  a.channel-val:hover { color: var(--accent); }

  .contact-form { display: flex; flex-direction: column; gap: var(--space-md); }
  .field { display: flex; flex-direction: column; gap: 0.45rem; }
  .field label { text-transform: uppercase; letter-spacing: 0.12em; font-size: var(--fs-label); color: var(--text-muted); }
  .field input,
  .field textarea {
    background: var(--bg-primary-darker);
    border: 1px solid var(--border);
    color: var(--text-heading);
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.75rem 0.9rem;
    resize: vertical;
    transition: border-color var(--dur) var(--ease);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  .contact-form .cta { align-self: flex-start; margin-top: var(--space-sm); }

  /* Honeypot — ekran dışı, erişilebilirlik ağacından da uzak */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-status {
    margin-top: var(--space-xs);
    padding: 0.75rem 0.9rem;
    border-left: 2px solid var(--border);
    max-width: 52ch;
    line-height: 1.5;
  }
  .form-status.is-success { border-left-color: var(--accent); color: var(--text-heading); }
  .form-status.is-error { border-left-color: #C25B4E; color: var(--text-body); }
  .form-status a { color: var(--accent); }

  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; gap: var(--space-xl); }
  }
</style>

<script is:inline define:vars={{ email: site.email }}>
  (function () {
    var form = document.getElementById('contact-form');
    if (!form) return;
    var status = document.getElementById('form-status');

    // Backend (Resend) şimdilik ertelendi — form yalnızca frontend'de.
    // Submit hiçbir istek atmaz; "yakında aktif olacak" bilgisini gösterir.
    var COPY = {
      soon: {
        en: 'The contact form isn’t live yet — it’s coming soon. In the meantime, email me directly at ',
        tr: 'İletişim formu henüz aktif değil, yakında aktif olacak. Şimdilik doğrudan e-posta gönderebilirsin: ',
      },
    };

    function lang() {
      return document.documentElement.getAttribute('data-lang') === 'tr' ? 'tr' : 'en';
    }

    // Dil-duyarlı placeholder'lar (attribute olduğu için CSS trick çalışmaz)
    function applyPlaceholders() {
      var l = lang();
      form.querySelectorAll('[data-ph-' + l + ']').forEach(function (inp) {
        inp.setAttribute('placeholder', inp.getAttribute('data-ph-' + l) || '');
      });
    }
    applyPlaceholders();
    new MutationObserver(applyPlaceholders).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-lang'],
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      status.hidden = false;
      status.className = 'form-status mono';
      status.innerHTML = COPY.soon[lang()] + '<a href="mailto:' + email + '">' + email + '</a>.';
    });
  })();
</script>
