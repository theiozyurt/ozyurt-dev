---
import BaseLayout from '../layouts/BaseLayout.astro';
import T from '../components/T.astro';
import GhostNumber from '../components/GhostNumber.astro';
import PixelField from '../components/PixelField.astro';
import PageBackground from '../components/PageBackground.astro';
import portfolio from '../data/portfolio.json';

const bi = (v: any) => (typeof v === 'string' ? { en: v, tr: v } : v);
---

<BaseLayout
  path="/portfolio"
  title="Portfolio"
  description="Websites designed and coded by İsmail Özyurt — the Ceviz Biyoteknoloji brand site, and sites for local businesses in Kütahya. Each one, its purpose, and what it's built with."
  descriptionTr="İsmail Özyurt'un tasarlayıp kodladığı web siteleri — Ceviz Biyoteknoloji marka sitesi ve Kütahya'daki yerel işletmeler için siteler. Her biri, amacı ve hangi teknolojiyle yapıldığı."
>
  <PageBackground motif="skyline" />

  <header class="page-head section ghost-host">
    <GhostNumber n="01" />
    <PixelField count={14} />
    <div class="container">
      <span class="section-label"><T en="Portfolio" tr="Portfolyo" /></span>
      <h1><T en="Websites I've built." tr="Yaptığım web siteleri." /></h1>
      <p class="page-lead">
        <T
          en="A few sites I designed and coded — for my own company and for local businesses in Kütahya. Each one below: where it points, what it's for, and what it's built with."
          tr="Tasarlayıp kodladığım birkaç site — kendi şirketim ve Kütahya'daki yerel işletmeler için. Aşağıda her biri: nereye gittiği, ne işe yaradığı ve hangi teknolojiyle yapıldığı."
        />
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="pf-list">
        {portfolio.map((p) => (
          <a href={p.url} target="_blank" rel="noopener" class="pf-card">
            <div class="pf-head">
              <h2 class="pf-title">{p.title}</h2>
              <span class="pf-url mono">
                {p.urlLabel}<span class="pf-url-arrow" aria-hidden="true"> ↗</span>
              </span>
            </div>
            <p class="pf-purpose"><T t={bi(p.purpose)} /></p>
            <div class="pf-meta">
              <ul class="pf-tags" aria-label="Built with">
                {p.tech.map((t) => <li class="tag tag--ghost">{t}</li>)}
              </ul>
              <span class="pf-lang mono">
                <T en="Site language" tr="Site dili" />: <T t={bi(p.lang)} />
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { border-top: none; padding-bottom: var(--space-lg); }
  .page-lead { color: var(--text-body); font-size: 1.15rem; margin-top: var(--space-md); max-width: 62ch; }

  .pf-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .pf-card {
    display: block;
    padding: var(--space-lg) var(--space-xl);
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius-md);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: transform 0.25s var(--ease), background 0.25s var(--ease),
      border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .pf-card:hover {
    transform: translateY(-4px);
    background: var(--surface-strong);
    border-color: var(--border-strong);
    border-left-color: var(--accent);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .pf-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .pf-title { font-size: var(--fs-h2); color: var(--text-heading); }
  .pf-url {
    color: var(--accent);
    font-size: var(--fs-small);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .pf-card:hover .pf-url-arrow { color: var(--accent); }

  .pf-purpose {
    color: var(--text-body);
    margin-top: var(--space-sm);
    max-width: 68ch;
  }

  .pf-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }
  .pf-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .pf-lang {
    font-size: var(--fs-label);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .pf-card { padding: var(--space-lg); }
    .pf-meta { align-items: flex-start; }
  }
</style>
