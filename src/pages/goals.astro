---
import BaseLayout from '../layouts/BaseLayout.astro';
import T from '../components/T.astro';
import Cta from '../components/Cta.astro';
import GhostNumber from '../components/GhostNumber.astro';
import PixelField from '../components/PixelField.astro';
import PageBackground from '../components/PageBackground.astro';
---

<BaseLayout
  path="/goals"
  title="Goals"
  description="İsmail Özyurt on where this is going — building things that work end-to-end, and figuring out what shape that takes long-term."
  descriptionTr="Bu işin nereye gittiğine dair düşüncelerim — bir fikri baştan sona gerçek bir ürüne dönüştürmek ve bunun uzun vadede alacağı şekil."
>
  <PageBackground motif="trail" />

  <header class="page-head section ghost-host">
    <GhostNumber n="01" />
    <PixelField count={14} />
    <div class="container">
      <span class="section-label"><T en="Goals" tr="Hedefler" /></span>
      <h1><T en="Where this is going" tr="Bundan sonrası" /></h1>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="goals-body">
      <blockquote class="goals-lead quote-block">
        <T
          en="Turning an idea into a real product that people actively use, end to end, is my biggest motivation. It's that act of making that draws me in — in my work at Ceviz Biyoteknoloji and in the projects I run. I'm still figuring out exactly where this journey leads long-term, but I'll keep making, leading, and learning how to get strong teams and projects in sync."
          tr="Bir fikri baştan sona, insanların aktif olarak kullandığı gerçek bir ürüne dönüştürmek en büyük motivasyon kaynağım. Ceviz Biyoteknoloji'deki çalışmalarımda ve yürüttüğüm projelerde beni çeken ana güç bu üretim sürecidir. Gelecekte bu yolculuğun tam olarak nereye evrileceğini henüz keşfediyor olsam da üretmeye, liderlik yapmaya ve başarılı ekipler ile projeleri nasıl senkronize edeceğimi öğrenmeye odaklanmaya devam edeceğim."
        />
      </blockquote>

      <p class="goals-pull">
        <T en="Build. Lead. Learn." tr="Geliştir. Yönet. Öğren." />
      </p>

      <div class="goals-cta">
        <Cta href="/projects" variant="primary" cursor>
          <T en="See what I'm building" tr="Neler geliştirdiğime bak" />
        </Cta>
        <Cta href="/contact" variant="secondary">
          <T en="Get in touch" tr="İletişime geç" />
        </Cta>
      </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-head { border-top: none; padding-bottom: var(--space-lg); }
  .goals-body { max-width: 760px; }

  .goals-lead {
    font-family: var(--font-body);
    font-size: clamp(1.15rem, 1.8vw, 1.5rem);
    line-height: 1.5;
    color: var(--text-heading);
  }

  .goals-pull {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--accent);
    letter-spacing: -0.01em;
    margin-top: var(--space-xl);
    max-width: none;
  }

  .goals-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }
</style>
