---
import BaseLayout from '../../layouts/BaseLayout.astro';
import T from '../../components/T.astro';
import Cta from '../../components/Cta.astro';
import GhostNumber from '../../components/GhostNumber.astro';
import PixelField from '../../components/PixelField.astro';
import CardExpandScript from '../../components/CardExpandScript.astro';
import leadership from '../../data/leadership.json';

const bi = (v: any) => (typeof v === 'string' ? { en: v, tr: v } : v);
---

<BaseLayout
  path="/leadership"
  title="Leadership"
  description="Community & leadership by İsmail Özyurt — founding president of KSBÜ Teknofest Club, Deneyap mentor, T3 Foundation scholar, and ÜNİDES project coordinator."
>
  <header class="page-head section ghost-host">
    <GhostNumber n="01" />
    <PixelField count={14} />
    <div class="container">
      <span class="section-label"><T en="Leadership" tr="Liderlik" /></span>
      <h1><T en="Community, at a realistic scale." tr="Topluluk, gerçekçi bir ölçekte." /></h1>
      <p class="page-lead">
        <T
          en="No inflated titles — just roles I actually hold and what they've produced."
          tr="Abartılı unvanlar yok — gerçekten üstlendiğim roller ve ortaya çıkardıkları işler."
        />
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="lead-list" id="lead-list">
        {leadership.map((item) => (
          <article class="lead-item leadership-item">
            <div class="lead-side">
              <span class="mono lead-period"><T t={bi(item.period)} /></span>
            </div>
            <div class="lead-body">
              <h2 class="lead-org"><T t={bi(item.org)} /></h2>
              <span class="lead-role mono"><T t={bi(item.role)} /></span>
              <p class="lead-summary item-description"><T t={bi(item.summary)} /></p>
              {item.points && item.points.length > 0 && (
                <ul class="lead-points">
                  {item.points.map((p) => (
                    <li><T t={bi(p)} /></li>
                  ))}
                </ul>
              )}
              {item.gallery && item.gallery.length > 0 && (
                <div class="item-gallery-preview" aria-hidden="true" data-lightbox-group>
                  {item.gallery.slice(0, 3).map((img) => (
                    <button type="button" class="preview-shot" tabindex="-1" data-lightbox>
                      <img src={img} alt="" loading="lazy" />
                    </button>
                  ))}
                </div>
              )}
              <Cta href={`/leadership/${item.slug}`} variant="secondary" class="lead-link">
                <T en="View details" tr="Detayları gör" />
              </Cta>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CardExpandScript />
</BaseLayout>

<style>
  .page-head { border-top: none; padding-bottom: var(--space-lg); }
  .page-lead { color: var(--text-body); font-size: 1.15rem; margin-top: var(--space-md); max-width: 58ch; }

  .lead-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .lead-item {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .lead-period { display: block; padding-top: 0.3rem; }
  .lead-org { font-size: var(--fs-h3); }
  .lead-role {
    display: block;
    color: var(--accent);
    margin: 0.3rem 0 var(--space-sm);
  }
  .lead-summary { color: var(--text-body); }
  .lead-points {
    list-style: none;
    margin-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .lead-points li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--text-body);
    max-width: 64ch;
  }
  .lead-points li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .lead-link { margin-top: var(--space-lg); }

  @media (max-width: 720px) {
    .lead-item { grid-template-columns: 1fr; gap: var(--space-xs); padding: var(--space-lg); }
  }
</style>
