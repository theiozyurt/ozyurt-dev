---
import BaseLayout from '../../layouts/BaseLayout.astro';
import T from '../../components/T.astro';
import Cta from '../../components/Cta.astro';
import MediaPlaceholder from '../../components/MediaPlaceholder.astro';
import Gallery from '../../components/Gallery.astro';

// Ürün kartlarındaki splash görselleri dışında kalan ekran görüntüleri,
// her ürün için ayrı galeriler halinde.
const cevizAppShots = [
  '/images/projects/ceviz/app/1781127254872.jpeg',
  '/images/projects/ceviz/app/1781127255254.jpeg',
];
const converterShots = [
  '/images/projects/ceviz/viewer_converter/IMG_1409.jpeg',
  '/images/projects/ceviz/viewer_converter/IMG_1410.jpeg',
  '/images/projects/ceviz/viewer_converter/IMG_1411.jpeg',
  '/images/projects/ceviz/viewer_converter/IMG_1412.jpeg',
];
---

<BaseLayout
  path="/projects/ceviz"
  title="Ceviz Biyoteknoloji"
  description="Case study: Ceviz Biyoteknoloji — a TÜBİTAK-funded biotech startup where İsmail Özyurt is Developer & Partner. Ceviz App, Ceviz Viewer & Converter, and a KVKK/GDPR DICOM anonymization pipeline."
>
  <header class="case-head section">
    <div class="container">
      <a href="/projects" class="back-link mono">← <T en="All projects" tr="Tüm projeler" /></a>
      <div class="case-eyebrow">
        <span class="tag"><T en="Case study" tr="Detaylı inceleme" /></span>
        <span class="mono"><T en="Developer & Partner · 2025 — Present" tr="Developer & Partner · 2025 — Devam ediyor" /></span>
      </div>
      <h1 class="case-title">Ceviz Biyoteknoloji</h1>
      <blockquote class="case-intro quote-block">
        <T
          en="A TÜBİTAK-funded biotech startup building the bridge between physicians and engineers — from raw CT/MRI to a manufacturable 3D implant. I'm the sole developer and a project partner alongside Emirhan Bozoğlan and Abdüssamet Doğan."
          tr="Hekimlerle mühendisler arasında köprü kuran, TÜBİTAK destekli bir biyoteknoloji girişimi — ham BT/MR'dan üretilebilir 3D implanta. Emirhan Bozoğlan ve Abdüssamet Doğan ile birlikte tek geliştirici ve proje ortağıyım."
        />
      </blockquote>
    </div>
  </header>

  <!-- Hızlı bilgiler -->
  <section class="section">
    <div class="container">
      <dl class="facts">
        <div class="fact">
          <dt class="mono"><T en="My role" tr="Rolüm" /></dt>
          <dd><T en="Developer & Partner (sole developer)" tr="Developer & Partner (tek geliştirici)" /></dd>
        </div>
        <div class="fact">
          <dt class="mono"><T en="Funding" tr="Destek" /></dt>
          <dd><T en="TÜBİTAK 1501 & 1812 Industrial R&D" tr="TÜBİTAK 1501 & 1812 Sanayi Ar-Ge" /></dd>
        </div>
        <div class="fact">
          <dt class="mono"><T en="Domain" tr="Alan" /></dt>
          <dd><T en="Medical imaging · 3D implants" tr="Tıbbi görüntüleme · 3D implant" /></dd>
        </div>
        <div class="fact">
          <dt class="mono">Stack</dt>
          <dd>Flutter · Firebase · Python · DICOM</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- İki ürün -->
  <section class="section section--darker">
    <div class="container">
      <span class="section-label"><T en="Two products" tr="İki ürün" /></span>
      <div class="products">
        <article class="product">
          <span class="product-index">01</span>
          <h2 class="product-name">Ceviz App</h2>
          <p class="product-kind mono"><T en="B2B platform · Mobile + Web" tr="B2B platform · Mobil + Web" /></p>
          <p>
            <T
              en="A platform that connects hospitals and physicians with engineers for 3D implant and prosthetic design. Built with Flutter and Firebase, and live on both Google Play and the App Store."
              tr="Hastaneleri ve hekimleri, 3D implant ve protez tasarımı için mühendislerle buluşturan bir platform. Flutter ve Firebase ile geliştirildi; hem Google Play hem App Store'da yayında."
            />
          </p>
          <MediaPlaceholder src="/images/projects/ceviz/app/1781127259880.jpeg" alt="Ceviz App splash ekranı" label="Ceviz App" ratio="16 / 10" />
        </article>
        <article class="product">
          <span class="product-index">02</span>
          <h2 class="product-name">Ceviz Viewer & Converter</h2>
          <p class="product-kind mono"><T en="3D viewer & converter · Mobile + Web" tr="3D görüntüleyici & dönüştürücü · Mobil + Web" /></p>
          <p>
            <T
              en="A separate 3D viewer and converter supporting 30+ formats, planned as a standalone product and currently in testing. It turns the messy reality of medical and 3D file formats into something a clinician or engineer can actually open and work with."
              tr="30+ format destekleyen, bağımsız ürün olarak planlanan ve şu an test aşamasında olan ayrı bir 3D görüntüleyici ve dönüştürücü. Tıbbi ve 3D dosya formatlarının karmaşasını, bir klinisyen ya da mühendisin gerçekten açıp çalışabileceği bir şeye dönüştürüyor."
            />
          </p>
          <MediaPlaceholder src="/images/projects/ceviz/viewer_converter/IMG_1408.jpeg" alt="Ceviz Viewer & Converter splash ekranı" label="Ceviz Viewer & Converter" ratio="16 / 10" />
        </article>
      </div>
    </div>
  </section>

  <!-- Ekran görüntüleri — her ürün ayrı -->
  <section class="section">
    <div class="container">
      <span class="section-label"><T en="Screenshots" tr="Ekran görüntüleri" /></span>
      <Gallery images={cevizAppShots} heading="[ CEVIZ APP ]" />
      <Gallery images={converterShots} heading="[ VIEWER & CONVERTER ]" />
    </div>
  </section>

  <!-- Teknik derinlik -->
  <section class="section">
    <div class="container case-narrow">
      <span class="section-label"><T en="Engineering depth" tr="Mühendislik derinliği" /></span>
      <h2 class="case-h2"><T en="The DICOM anonymization pipeline" tr="DICOM anonimleştirme hattı" /></h2>
      <p>
        <T
          en="Patient CT and MRI scans arrive as DICOM files carrying identifying metadata. Before anything else can happen, that data has to be stripped and handled lawfully. I designed and implemented a Python pipeline running on Firebase (europe-west3) that anonymizes this imaging for KVKK/GDPR compliance — keeping the geometry clinicians need while removing the identity they don't."
          tr="Hasta BT ve MR taramaları, kimlik bilgisi taşıyan meta verilerle birlikte DICOM dosyaları olarak geliyor. Başka hiçbir şey olmadan önce, bu veri hukuka uygun biçimde temizlenmeli. Bu görüntüleri KVKK/GDPR uyumu için anonimleştiren, Firebase (europe-west3) üzerinde çalışan bir Python hattı tasarlayıp geliştirdim — klinisyenlerin ihtiyaç duyduğu geometriyi korurken ihtiyaç duymadıkları kimliği kaldırıyor."
        />
      </p>

      <h2 class="case-h2"><T en="Beyond the code" tr="Kodun ötesinde" /></h2>
      <p>
        <T
          en="I also hand-coded the brand website in HTML5 and CSS3 — deliberately avoiding off-the-shelf WordPress components — with performance and SEO as first-class goals. As a project partner, engineering here isn't a task list; it's part of deciding what the product should be."
          tr="Marka web sitesini de HTML5 ve CSS3 ile elle kodladım — hazır WordPress bileşenlerinden bilinçle kaçınarak — performans ve SEO'yu birincil hedef alarak. Proje ortağı olarak buradaki mühendislik bir görev listesi değil; ürünün ne olması gerektiğine karar vermenin bir parçası."
        />
      </p>
    </div>
  </section>

  <!-- Web siteleri -->
  <section class="section">
    <div class="container">
      <span class="section-label"><T en="Websites" tr="Web siteleri" /></span>
      <h2 class="case-h2"><T en="Three sites, hand-coded" tr="Üç site, elle kodlandı" /></h2>
      <p class="websites-intro">
        <T
          en="Under the Ceviz Biyoteknoloji umbrella I hand-coded three separate websites in HTML5/CSS3 — free of off-the-shelf template constraints, with performance and SEO as first-class goals."
          tr="Ceviz Biyoteknoloji çatısı altında üç ayrı web sitesini HTML5/CSS3 ile sıfırdan kodladım — hazır şablon kısıtlamalarından bağımsız, performans ve SEO odaklı."
        />
      </p>
      <div class="website-cards">
        <a href="https://cevizbiotech.com" target="_blank" rel="noopener" class="website-card">
          <span class="website-label"><T en="Main site" tr="Ana site" /></span>
          <span class="website-url mono">cevizbiotech.com</span>
          <span class="website-desc"><T en="Brand & showcase site" tr="Marka ve tanıtım sitesi" /></span>
          <span class="website-cta"><T en="Visit" tr="Siteyi gör" /> <span class="cta-arrow" aria-hidden="true">→</span></span>
        </a>
        <a href="https://cevizbiotech.com/app" target="_blank" rel="noopener" class="website-card">
          <span class="website-label">Ceviz App</span>
          <span class="website-url mono">cevizbiotech.com/app</span>
          <span class="website-desc"><T en="Physician–engineer B2B platform, web showcase" tr="Hekim-mühendis B2B platformu, web tanıtımı" /></span>
          <span class="website-cta"><T en="Visit" tr="Siteyi gör" /> <span class="cta-arrow" aria-hidden="true">→</span></span>
        </a>
        <a href="https://cevizbiotech.com/viewer" target="_blank" rel="noopener" class="website-card">
          <span class="website-label">Ceviz Viewer & Converter</span>
          <span class="website-url mono">cevizbiotech.com/viewer</span>
          <span class="website-desc"><T en="3D viewer/converter, web showcase" tr="3D görüntüleyici/dönüştürücü, web tanıtımı" /></span>
          <span class="website-cta"><T en="Visit" tr="Siteyi gör" /> <span class="cta-arrow" aria-hidden="true">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <section class="section section--darker">
    <div class="container cta-band">
      <h2><T en="Want the rest of the story?" tr="Hikâyenin devamını ister misin?" /></h2>
      <div class="cta-actions">
        <Cta href="/experience" variant="secondary"><T en="See experience" tr="Deneyime bak" /></Cta>
        <Cta href="/contact" variant="primary" cursor><T en="Get in touch" tr="İletişime geç" /></Cta>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .case-head { border-top: none; padding-bottom: var(--space-lg); }
  .back-link { display: inline-block; margin-bottom: var(--space-lg); color: var(--text-muted); }
  .back-link:hover { color: var(--accent); }
  .case-eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .case-title { font-size: var(--fs-display); margin-bottom: var(--space-lg); }
  .case-intro {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.4vw, 1.9rem);
    line-height: 1.3;
    color: var(--text-heading);
    max-width: 34ch;
  }

  .facts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }
  .fact {
    padding: var(--space-lg);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .fact dt {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--fs-label);
    margin-bottom: 0.5rem;
  }
  .fact dd { color: var(--text-heading); font-weight: 500; }

  .products {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }
  .product {
    padding: var(--space-lg);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .product-index { font-family: var(--font-body); font-size: var(--fs-label); letter-spacing: 0.14em; color: var(--accent); }
  .product-name { font-size: var(--fs-h2); }
  .product p { color: var(--text-body); }

  .case-narrow { max-width: 760px; }
  .case-h2 { font-size: var(--fs-h2); margin: var(--space-xl) 0 var(--space-md); }
  .case-narrow > .case-h2:first-of-type { margin-top: var(--space-md); }
  .case-narrow p { max-width: none; }

  .websites-intro { color: var(--text-body); max-width: 640px; margin-bottom: var(--space-lg); }
  .website-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-md);
  }
  .website-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: var(--space-lg);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: transform 0.25s var(--ease), background 0.25s var(--ease),
      border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .website-card:hover {
    transform: translateY(-4px);
    background: var(--surface-strong);
    border-color: var(--border-strong);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }
  .website-label { font-family: var(--font-display); font-size: 1.15rem; color: var(--text-heading); }
  .website-url { font-size: var(--fs-label); color: var(--text-muted); }
  .website-desc { font-size: var(--fs-small); color: var(--text-body); }
  .website-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-sm);
    font-weight: 600;
    font-size: 14px;
    color: var(--accent);
  }
  .website-card:hover .website-cta .cta-arrow { transform: translateX(4px); }

  .cta-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .cta-band h2 { font-size: var(--fs-h2); max-width: 20ch; }
  .cta-actions { display: flex; gap: var(--space-md); flex-wrap: wrap; }

  @media (max-width: 820px) {
    .facts { grid-template-columns: 1fr 1fr; }
    .products { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .facts { grid-template-columns: 1fr; }
  }
</style>
