---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import T from '../components/T.astro';
import Cta from '../components/Cta.astro';
import GhostNumber from '../components/GhostNumber.astro';
---

<BaseLayout path="/">
  <Hero />

  <!-- Öne çıkan üç şey -->
  <section class="section section--darker ghost-host">
    <GhostNumber n="02" />
    <div class="container">
      <span class="section-label">
        <T en="What I'm building" tr="Üzerinde Çalıştıklarım" />
      </span>

      <div class="feature-grid">
        <article class="feature">
          <span class="feature-index">01</span>
          <h2 class="feature-title">Ceviz Biyoteknoloji</h2>
          <p class="feature-lead mono"><T en="Developer & Partner · Now" tr="Developer & Partner · Şimdi" /></p>
          <p>
            <T
              en="A TÜBİTAK-funded biotech startup. I build two products: a physician–engineer B2B platform and a 30+ format 3D viewer & converter — plus the KVKK/GDPR DICOM pipeline behind them."
              tr="TÜBİTAK destekli bir biyoteknoloji girişimi. İki ürün geliştiriyorum: hekim–mühendis B2B platformu ve 30+ format destekli 3D görüntüleyici/dönüştürücü — ve arkalarındaki KVKK/GDPR DICOM hattı."
            />
          </p>
          <Cta href="/projects/ceviz" variant="secondary" class="feature-link">
            <T en="Read the case study" tr="Nasıl geliştirdiğimi oku" />
          </Cta>
        </article>

        <article class="feature">
          <span class="feature-index">02</span>
          <h2 class="feature-title"><T en="Research & internships" tr="Araştırma & stajlar" /></h2>
          <p class="feature-lead mono"><T en="Salerno, Güral, Gürok · Track record" tr="Salerno, Güral, Gürok · Geçmiş" /></p>
          <p>
            <T
              en="Computer-vision research at the University of Salerno (2024), enterprise Flutter at Güral Porselen, and a current software internship at Gürok Group — each has deepened my engineering experience."
              tr="Salerno Üniversitesi'nde bilgisayarlı görü araştırması (2024), Güral Porselen'de kurumsal Flutter deneyimi ve şu an sürmekte olan Gürok Group stajı — her biri mühendislik deneyimimi biraz daha derinleştirdi."
            />
          </p>
          <Cta href="/experience" variant="secondary" class="feature-link">
            <T en="See the timeline" tr="Zaman çizelgesine bak" />
          </Cta>
        </article>

        <article class="feature">
          <span class="feature-index">03</span>
          <h2 class="feature-title"><T en="Where this is going" tr="Bundan sonrası" /></h2>
          <p class="feature-lead mono"><T en="The bigger picture · Ahead" tr="Büyük resim · İleride" /></p>
          <p>
            <T
              en="Everything above has shaped where I am today. Academic work, leading KSBÜ Teknofest Club, mentoring — deliberate practice at building things that actually work end to end. I'm still figuring out exactly where it leads."
              tr="Yukarıdaki her şey beni bugüne getirdi. Akademik çalışmalar, KSBÜ Teknofest Topluluğu'nu yönetmek, mentorluk — baştan sona işleyen şeyler üretmek için bilinçli bir pratik. Uzun vadede beni nereye götüreceğini hâlâ keşfediyorum."
            />
          </p>
          <Cta href="/goals" variant="secondary" class="feature-link">
            <T en="Where I'm headed" tr="Devamını gör" />
          </Cta>
        </article>
      </div>
    </div>
  </section>

  <!-- Kısa yönlendirmeler -->
  <section class="section ghost-host">
    <GhostNumber n="03" />
    <div class="container directory">
      <div class="directory-intro">
        <span class="section-label"><T en="Explore more" tr="Yakından incele" /></span>
        <h2>
          <T
            en="The full picture."
            tr="Hepsi bir arada."
          />
        </h2>
        <figure class="intro-photo">
          <img
            src="/images/selcuk_bayraktar.jpeg"
            alt="İsmail Özyurt, Selçuk Bayraktar'a Teknofest Kulübü plaketini takdim ederken"
            width="760"
            height="900"
            loading="lazy"
          />
          <figcaption><T en="With Selçuk Bayraktar · TEKNOFEST" tr="Selçuk Bayraktar ile · TEKNOFEST" /></figcaption>
        </figure>
      </div>
      <nav class="directory-links" aria-label="Sections">
        <a href="/experience" class="dir-row">
          <span class="dir-num">01</span>
          <span class="dir-name"><T en="Experience" tr="Deneyim" /></span>
          <span class="dir-desc mono"><T en="Timeline of work & research" tr="İş ve araştırma zaman çizelgesi" /></span>
        </a>
        <a href="/projects" class="dir-row">
          <span class="dir-num">02</span>
          <span class="dir-name"><T en="Projects" tr="Projeler" /></span>
          <span class="dir-desc mono"><T en="Ceviz, Birth Adventure & more" tr="Ceviz, Birth Adventure ve daha fazlası" /></span>
        </a>
        <a href="/leadership" class="dir-row">
          <span class="dir-num">03</span>
          <span class="dir-name"><T en="Leadership" tr="Liderlik" /></span>
          <span class="dir-desc mono"><T en="Teknofest Club, Deneyap, T3, ÜNİDES" tr="Teknofest Topluluğu, Deneyap, T3, ÜNİDES" /></span>
        </a>
        <a href="/goals" class="dir-row">
          <span class="dir-num">04</span>
          <span class="dir-name"><T en="Goals" tr="Hedefler" /></span>
          <span class="dir-desc mono"><T en="Where this is going" tr="Bundan sonrası" /></span>
        </a>
        <a href="/cv" class="dir-row">
          <span class="dir-num">05</span>
          <span class="dir-name"><T en="CV" tr="Özgeçmiş" /></span>
          <span class="dir-desc mono"><T en="Full résumé, web & print" tr="Tam özgeçmiş, web ve baskı" /></span>
        </a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }
  .feature {
    padding: var(--space-lg);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: transform 0.25s var(--ease), background 0.25s var(--ease),
      border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .feature:hover {
    transform: translateY(-4px);
    background: var(--surface-strong);
    border-color: var(--border-strong);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }
  .feature-index {
    font-family: var(--font-body);
    font-size: var(--fs-label);
    letter-spacing: 0.14em;
    color: var(--accent);
  }
  .feature-title { font-size: var(--fs-h3); }
  .feature-lead { margin-bottom: var(--space-2xs); }
  .feature p { color: var(--text-body); }
  .feature-link {
    margin-top: auto;
    padding-top: var(--space-md);
    align-self: flex-start;
  }

  .directory {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: var(--space-xl);
    align-items: start;
  }
  .directory-intro h2 { max-width: 14ch; }
  .intro-photo {
    margin-top: var(--space-xl);
    max-width: 360px;
  }
  .intro-photo img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .intro-photo figcaption {
    margin-top: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--fs-small);
    letter-spacing: 0.02em;
    color: var(--text-muted);
  }
  .directory-links {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }
  .dir-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    grid-template-areas: 'num name' 'num desc';
    row-gap: 0.25rem;
    column-gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border-faint);
    align-items: baseline;
    transition: padding-left var(--dur) var(--ease);
  }
  .dir-row:hover { padding-left: 0.75rem; }
  .dir-num {
    grid-area: num;
    font-family: var(--font-body);
    font-size: var(--fs-small);
    color: var(--accent);
  }
  .dir-name {
    grid-area: name;
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    color: var(--text-heading);
  }
  .dir-desc { grid-area: desc; }

  @media (max-width: 820px) {
    .feature-grid { grid-template-columns: 1fr; }
    .directory { grid-template-columns: 1fr; gap: var(--space-lg); }
  }
</style>
